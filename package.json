{
  "name": "fzautochoice",
  "version": "1.0.0",
  "description": "Cross-platform auto-click desktop application with OCR dialog detection, AI integration, and schema management",
  "main": "./out/main/index.js",
  "author": {
    "name": "Roger Luft",
    "email": "roger@webstorage.com.br",
    "url": "https://about.rogerluft.com.br"
  },
  "license": "CC-BY-4.0",
  "homepage": "https://about.rogerluft.com.br",
  "repository": {
    "type": "git",
    "url": "https://github.com/RLuf/fzautochose.git"
  },
  "scripts": {
    "dev": "node node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node node_modules/electron-vite/bin/electron-vite.js build",
    "preview": "node node_modules/electron-vite/bin/electron-vite.js preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node node_modules/vitest/vitest.mjs run",
    "build:linux": "npm run build && node node_modules/electron-builder/cli.js --linux",
    "build:win": "npm run build && node node_modules/electron-builder/cli.js --win",
    "build:all": "npm run build && node node_modules/electron-builder/cli.js --linux --win",
    "release": "npm run build && node node_modules/electron-builder/cli.js --linux --win --publish always"
  },
  "dependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
